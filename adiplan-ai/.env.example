# Copy this to .env.local and fill in keys to enable optional features.
# Everything has a graceful fallback — the app works fully without any of these.

# --- Next.js dev (LAN only) ---
# If you use http://YOUR_LAN_IP:3000 instead of localhost, set your machine IP so
# dev `/_next/*` assets are not blocked. Omit this when using localhost only.
# DEV_LAN_ALLOWED_ORIGINS=192.168.8.143

# --- LLM (used by match-article, studios; prefer Anthropic for Vision ingest) ---
OPENAI_API_KEY=

# --- Workshop mode (live cursors + presence on the Stakeholder Map) ---
# Free tier from https://liveblocks.io/dashboard/apikeys
# Without this, the map runs single-player.
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_API_KEY=

# --- Voiceover synthesis (per-scene playback in Swine Studio) ---
# https://elevenlabs.io/app/api-keys
# Without this, the Play buttons return a friendly "configure key" hint.
ELEVENLABS_API_KEY=
# Optional override — defaults to "Rachel" (multilingual)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Live competitor-news scraper (replaces the 8 seeded articles) ---
# When set, /api/articles fetches from this URL and normalises the response
# into the ScrapedArticle shape. The News Bridge surfaces a "Live · N · Xm
# ago" badge, with a manual Refresh button. Cache TTL is 5 min.
#
# Auto-detected response shapes (any of these works):
#   - top-level array of articles
#   - { "articles": [...] }
#   - { "items": [...] }
#
# Fields per article (any of these aliases is picked up):
#   id    | uuid | slug
#   title | headline | name
#   summary | description | excerpt | content
#   competitor | company | source | publisher
#   url | link | permalink
#   publishedAt | published_at | date | pubDate
#   species | categories | topics | tags  (filtered to aqua/poultry/ruminants/swine)
#   tags | keywords | labels
#   region | geo | country
#   language | lang
#
# Without these set, the app runs in Demo mode with the seeded articles.
# SCRAPER_API_URL=https://your-scraper.example.com
# SCRAPER_API_KEY=

# --- Anthropic Claude (match-article, studios, Claude Vision workshop ingest) ---
# Required for live LLM + POST /api/ingest-workshop-photo (flipcharts).
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Mistral Document OCR (tables + figures from PDFs) ---
# When set, POST /api/ingest-document uses https://api.mistral.ai/v1/ocr .
# Without it, the same route falls back to pdf-parse (body text only).
# https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Supabase (Singapore-region pilot — auth + persistence) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: Postgres connection URI (Dashboard → Project Settings → Database) — percent-encode special chars in password.
# Used by: npx supabase db query --file scripts/supabase-migrate.sql --db-url "$DATABASE_URL"
# DATABASE_URL=

# --- Mailgun (live email — per-tenant vars; example for tenant adisseo) ---
# ADIPLAN_ADISSEO_EMAIL_PROVIDER=mailgun
# ADIPLAN_ADISSEO_EMAIL_API_KEY=
# ADIPLAN_ADISSEO_EMAIL_FROM_DOMAIN=

# --- Distribution webhooks (HMAC verification on inbound callbacks) ---
# WEBHOOK_SIGNING_SECRET=

# --- Competitor news scraper (optional live articles; same vars documented above) ---
# SCRAPER_API_URL=https://your-scraper.example.com
# SCRAPER_API_KEY=
